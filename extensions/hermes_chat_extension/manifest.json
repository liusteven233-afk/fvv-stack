{
  "manifest_version": 3,
  "name": "Hermes Chat · 双模型对话",
  "version": "1.1",
  "description": "Hermes (DeepSeek) + Ollama 本地模型 双对话插件",
  "permissions": ["activeTab", "storage", "sidePanel"],
  "host_permissions": ["http://localhost:8000/*", "http://localhost:11434/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Hermes Chat",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.1688.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}

{
  "manifest_version": 3,
  "name": "FVV Stack - ML采集分析",
  "version": "1.0.0",
  "description": "ML商品数据采集工具",
  "permissions": ["storage", "sidePanel", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.mercadolibre.com/*",
    "https://*.mercadolibre.com.mx/*",
    "https://*.mercadolibre.com.br/*",
    "https://*.mercadolibre.com.ar/*",
    "https://*.mercadolibre.cl/*",
    "https://*.mercadolibre.com.co/*",
    "https://*.mercadolibre.com.uy/*",
    "http://127.0.0.1:8649/*"
  ],
  "background": {"service_worker": "background.js"},
  "content_scripts": [
    {
      "matches": [
        "https://*.mercadolibre.com/*",
        "https://*.mercadolibre.com.mx/*",
        "https://*.mercadolibre.com.br/*",
        "https://*.mercadolibre.com.ar/*",
        "https://*.mercadolibre.cl/*",
        "https://*.mercadolibre.com.co/*",
        "https://*.mercadolibre.com.uy/*"
      ],
      "js": ["scripts/inject_scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://detail.1688.com/*", "https://*.1688.com/*"],
      "js": ["scripts/ali_scraper.js"],
      "run_at": "document_end"
    }
  ],
  "side_panel": {"default_path": "sidepanel/sidepanel.html"},
  "action": {"default_title": "FVV Stack", "default_icon": {"16": "icons/icon16.png","48": "icons/icon48.png","128": "icons/icon128.png"}},
  "icons": {"16": "icons/icon16.png","48": "icons/icon48.png","128": "icons/icon128.png"}
}
